<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>DrugLike AI — Molecular Intelligence Platform</title>

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>

  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;1,400;1,700&family=Space+Grotesk:wght@300;400;500;600;700&family=JetBrains+Mono:wght@300;400;500&display=swap" rel="stylesheet"/>

  <!-- CSS -->
  <link rel="stylesheet" href="style.css"/>
</head>

<body>

<div id="cur"></div>
<div id="curT"></div>

<div class="aurora">
  <div class="blob blob1"></div>
  <div class="blob blob2"></div>
  <div class="blob blob3"></div>
</div>

<canvas id="bgC"></canvas>

<!-- NAV -->
<nav>
  <div class="logo-wrap">
    <div class="logo-icon">⬡</div>
    <div class="logo-text">Drug<span>Like</span> AI</div>
  </div>

  <ul class="nav-center">
    <li><a href="#how">Process</a></li>
    <li><a href="#features">Features</a></li>
    <li><a href="#demo">Demo</a></li>
    <li><a href="#rules">Rules</a></li>
  </ul>

  <a href="https://github.com/Dubakrishnamohan/drug-likeness-code"
     target="_blank"
     class="nav-right">
     ⎇ &nbsp;GitHub
  </a>
</nav>

<!-- HERO -->
<section class="hero">

  <div class="hero-left">

    <div class="hero-eyebrow">
      <span class="eyebrow-dot"></span>
      <span class="eyebrow-text">ML-Powered · Open Source · Python</span>
    </div>

    <h1 class="hero-h1">
      <span class="line2">Predict</span>
      <span class="accent">Drug-Likeness</span>
      <span class="line2">Intelligently</span>
    </h1>

    <p class="hero-p">
      A computational pipeline that evaluates whether a molecule has the physicochemical properties to become a viable drug.
    </p>

    <div class="hero-actions">
      <a href="https://github.com/Dubakrishnamohan/drug-likeness-code"
         target="_blank"
         class="btn-glow">
         ⎇ &nbsp;View on GitHub
      </a>

      <a href="#how" class="btn-outline">
        ↓ &nbsp;Explore
      </a>
    </div>

    <div class="hero-chips">
      <span class="chip"><span class="chip-dot"></span>RDKit</span>
      <span class="chip"><span class="chip-dot"></span>scikit-learn</span>
      <span class="chip"><span class="chip-dot"></span>Python 3.x</span>
      <span class="chip"><span class="chip-dot"></span>Pandas</span>
      <span class="chip"><span class="chip-dot"></span>SMILES</span>
    </div>

  </div>

  <div class="hero-right">

    <div class="mol-stage">

      <div class="mol-ring"></div>
      <div class="mol-ring2"></div>

      <canvas id="heroMol"></canvas>

      <div class="mol-hud mol-hud-tl">
        <div class="hud-title">// aspirin.smiles</div>

        <div class="hud-row">
          <span>MW</span>
          <span class="hud-val">180.16 Da</span>
        </div>

        <div class="hud-row">
          <span>LogP</span>
          <span class="hud-val">1.19</span>
        </div>

        <div class="hud-row">
          <span>HBD</span>
          <span class="hud-val">1</span>
        </div>

        <div class="hud-badge">✓ Lipinski Pass</div>
      </div>

      <div class="mol-hud mol-hud-br">
        <div class="hud-title">// qed_score</div>

        <div class="hud-row">
          <span>Score</span>
          <span class="hud-val">0.582</span>
        </div>

        <div class="hud-row">
          <span>Confidence</span>
          <span class="hud-val">94.7%</span>
        </div>

        <div class="hud-row">
          <span>Status</span>
          <span class="hud-val" style="color:var(--c1)">Drug-Like ✓</span>
        </div>

        <div class="hud-badge">ML Prediction Active</div>
      </div>

    </div>

  </div>

</section>

<!-- JS -->
<script src="script.js"></script>

</body> 
</html>